<script src="/script.js" is:inline></script>
<script is:inline>
  // Popup open/close
  const openPopupBtn = document.getElementById('openPopup');
  const submitPopup = document.getElementById('submitPopup');
  const popupClose = document.getElementById('popupClose');

  if (openPopupBtn) {
    openPopupBtn.addEventListener('click', () => submitPopup.classList.add('open'));
  }

  if (popupClose) {
    popupClose.addEventListener('click', () => submitPopup.classList.remove('open'));
  }

  submitPopup?.addEventListener('click', (e) => {
    if (e.target === submitPopup) submitPopup.classList.remove('open');
  });

// Auto-open popup if ?submit=true in URL
if (window.location.search.includes('submit=true')) {
  submitPopup.classList.add('open');
}

  // Submit opportunity form via Formspree
  const submitOppForm = document.getElementById('submit-opp-form');
  if (submitOppForm) {
    submitOppForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = submitOppForm.querySelector('button[type="submit"]');
      btn.textContent = 'Submitting...';
      btn.disabled = true;

      const formData = new FormData(submitOppForm);
      const response = await fetch(submitOppForm.action, {
        method: 'POST',
        body: formData,
        headers: { 'Accept': 'application/json' }
      });

      if (response.ok) {
        document.getElementById('popup-form-content').style.display = 'none';
        document.getElementById('popup-success').style.display = 'flex';
      } else {
        btn.textContent = 'Submit Opportunity →';
        btn.disabled = false;
        alert('Something went wrong. Please try again or email us directly.');
      }
    });
  }
</script>
