    .about-hero {
      padding: 96px 0 72px;
      position: relative;
      overflow: hidden;
    }

    .about-hero::before {
      content: '';
      position: absolute;
      top: -200px; right: -200px;
      width: 600px; height: 600px;
      background: radial-gradient(ellipse, rgba(37,99,235,0.08) 0%, transparent 65%);
      pointer-events: none;
    }

    .about-hero .section-label { margin-bottom: 16px; }

    .about-hero h1 {
      font-size: clamp(2.2rem, 4vw, 3.2rem);
      font-weight: 800;
      letter-spacing: -1px;
      max-width: 700px;
      margin-bottom: 24px;
      line-height: 1.15;
    }

    .about-hero p {
      font-size: 1.1rem;
      color: var(--text-muted);
      max-width: 620px;
      line-height: 1.8;
    }

    .about-section {
      padding: 72px 0;
    }

    .about-section h2 {
      font-size: clamp(1.6rem, 3vw, 2.2rem);
      font-weight: 800;
      letter-spacing: -0.5px;
      margin-bottom: 20px;
    }

    .about-section p {
  font-size: 1.05rem;
  color: var(--text-mid);
  line-height: 1.85;
  max-width: 680px;
  margin-bottom: 16px;
  margin-left: auto;
  margin-right: auto;
}

    .what-we-do-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 24px;
      margin-top: 40px;
    }

    .what-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 28px;
      transition: all 0.3s;
    }

    .what-card:hover {
      border-color: rgba(37,99,235,0.25);
      box-shadow: var(--shadow);
      transform: translateY(-3px);
    }

    .what-card-icon {
      font-size: 2rem;
      margin-bottom: 16px;
      display: block;
    }

    .what-card h3 {
      font-size: 1.1rem;
      font-weight: 700;
      margin-bottom: 10px;
    }

    .what-card p {
      font-size: 14px;
      color: var(--text-muted);
      line-height: 1.65;
      margin: 0;
    }

    .founder-section {
      background: linear-gradient(135deg, rgba(37,99,235,0.04) 0%, rgba(34,197,94,0.03) 100%);
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
    }

    .founder-inner {
      display: flex;
      align-items: flex-start;
      gap: 48px;
      padding: 72px 0;
    }

    .founder-avatar {
      width: 96px;
      height: 96px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--blue), var(--green));
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-weight: 800;
      font-size: 2rem;
      color: white;
      flex-shrink: 0;
    }

    .founder-content h2 {
      font-size: clamp(1.6rem, 3vw, 2.2rem);
      font-weight: 800;
      letter-spacing: -0.5px;
      margin-bottom: 6px;
    }

@media (max-width: 768px) {
  .about-hero-img { display: none; }
}

    .founder-content .founder-title {
      font-size: 14px;
      font-weight: 600;
      color: var(--blue);
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .founder-content p {
      font-size: 1.05rem;
      color: var(--text-mid);
      line-height: 1.85;
      max-width: 640px;
      margin-bottom: 16px;
    }

    .founder-linkedin {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 9px 20px;
      background: #0A66C2;
      color: white;
      border-radius: var(--radius-sm);
      font-weight: 600;
      font-size: 14px;
      transition: all 0.2s;
      margin-top: 8px;
    }

    .founder-linkedin:hover {
      background: #084d94;
      transform: translateY(-1px);
      box-shadow: 0 4px 14px rgba(10,102,194,0.35);
    }

    .advertise-section {
      padding: 72px 0;
    }

    .advertise-box {
      background: linear-gradient(135deg, var(--navy) 0%, #0F2256 50%, #0D3B2E 100%);
      border-radius: var(--radius-lg);
      padding: 56px 64px;
      position: relative;
      overflow: hidden;
    }

    .advertise-box::before {
      content: '';
      position: absolute;
      top: -100px; right: -100px;
      width: 400px; height: 400px;
      background: radial-gradient(ellipse, rgba(37,99,235,0.2) 0%, transparent 65%);
    }

    .advertise-box::after {
      content: '';
      position: absolute;
      bottom: -80px; left: -50px;
      width: 300px; height: 300px;
      background: radial-gradient(ellipse, rgba(34,197,94,0.15) 0%, transparent 65%);
    }

    .advertise-inner {
      position: relative;
      z-index: 1;
      max-width: 580px;
    }

    .advertise-box .section-label { color: var(--green); }

    .advertise-box h2 {
      font-size: clamp(1.6rem, 3vw, 2.2rem);
      color: white;
      margin-bottom: 16px;
      letter-spacing: -0.5px;
    }

    .advertise-box p {
      color: rgba(255,255,255,0.65);
      line-height: 1.75;
      margin-bottom: 28px;
      font-size: 1.05rem;
    }

    .advertise-stats {
      display: flex;
      gap: 40px;
      margin-bottom: 32px;
      flex-wrap: wrap;
    }

    .advertise-stat .num {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 1.75rem;
      font-weight: 800;
      color: white;
    }

    .advertise-stat .label {
      font-size: 13px;
      color: rgba(255,255,255,0.5);
    }

    .contact-section {
      padding: 72px 0;
    }

    .contact-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 24px;
      margin-top: 40px;
    }

    .contact-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 28px;
      transition: all 0.3s;
    }

    .contact-card:hover {
      border-color: rgba(37,99,235,0.25);
      box-shadow: var(--shadow);
      transform: translateY(-3px);
    }

    .contact-card-icon {
      font-size: 1.75rem;
      margin-bottom: 14px;
      display: block;
    }

    .contact-card h4 {
      font-size: 1rem;
      font-weight: 700;
      margin-bottom: 6px;
    }

    .contact-card p {
      font-size: 13px;
      color: var(--text-muted);
      margin-bottom: 14px;
      line-height: 1.6;
    }

    .contact-card a.contact-link {
      font-size: 13px;
      font-weight: 600;
      color: var(--blue);
      display: flex;
      align-items: center;
      gap: 4px;
      transition: gap 0.2s;
    }

    .contact-card a.contact-link:hover { gap: 8px; }

    /* POPUP */
    .popup-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.6);
      backdrop-filter: blur(4px);
      z-index: 500;
      display: none;
      align-items: center;
      justify-content: center;
      padding: 24px;
    }

    .popup-overlay.open { display: flex; }

    .popup-box {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 40px;
      max-width: 560px;
      width: 100%;
      max-height: 90vh;
      overflow-y: auto;
      position: relative;
    }

    .popup-close {
      position: absolute;
      top: 16px; right: 16px;
      width: 36px; height: 36px;
      border-radius: 50%;
      border: 1px solid var(--border);
      background: var(--bg);
      cursor: pointer;
      font-size: 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--text-muted);
      transition: all 0.2s;
    }

    .popup-close:hover { color: var(--text); border-color: var(--border-dark); }

    .popup-box h3 {
      font-size: 1.4rem;
      font-weight: 800;
      margin-bottom: 6px;
      letter-spacing: -0.3px;
    }

    .popup-box .popup-sub {
      font-size: 14px;
      color: var(--text-muted);
      margin-bottom: 28px;
    }

    .form-group {
      margin-bottom: 18px;
    }

    .form-group label {
      display: block;
      font-size: 13px;
      font-weight: 600;
      color: var(--text);
      margin-bottom: 6px;
    }

    .form-group input,
    .form-group select,
    .form-group textarea {
      width: 100%;
      padding: 11px 14px;
      background: var(--bg);
      border: 1.5px solid var(--border);
      border-radius: var(--radius-sm);
      font-family: 'Outfit', sans-serif;
      font-size: 14px;
      color: var(--text);
      outline: none;
      transition: border-color 0.2s;
    }

    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus {
      border-color: var(--blue);
    }

    .form-group textarea { resize: vertical; min-height: 100px; }

    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
    }

    .popup-success {
      display: none;
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 20px 0;
      gap: 16px;
    }

    .popup-success h3 { margin-bottom: 0; }
    .popup-success p { color: var(--text-muted); font-size: 14px; }

    @media (max-width: 768px) {
      .founder-inner { flex-direction: column; gap: 24px; }
      .advertise-box { padding: 40px 28px; }
      .form-row { grid-template-columns: 1fr; }
      .about-hero { padding: 56px 0 48px; }
    }
  </style>

