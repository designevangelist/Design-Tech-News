<body>

<!-- SUBMIT OPPORTUNITY POPUP -->
<div class="popup-overlay" id="submitPopup">
  <div class="popup-box">
    <button class="popup-close" id="popupClose">✕</button>
    <div id="popup-form-content">
      <h3>Submit an Opportunity</h3>
      <p class="popup-sub">Know of a scholarship, fellowship, internship, or accelerator? Share it with our community.</p>
      <form id="submit-opp-form" action="https://formspree.io/f/xbdzakye" method="POST">
        <div class="form-row">
          <div class="form-group">
            <label>Your Name *</label>
            <input type="text" name="name" required placeholder="John Doe" />
          </div>
          <div class="form-group">
            <label>Your Email *</label>
            <input type="email" name="email" required placeholder="you@example.com" />
          </div>
        </div>
        <div class="form-group">
          <label>Opportunity Title *</label>
          <input type="text" name="title" required placeholder="e.g. Google for Startups Africa" />
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Type *</label>
            <select name="type" required>
              <option value="">Select type</option>
              <option>Scholarship</option>
              <option>Fellowship</option>
              <option>Internship</option>
              <option>Accelerator</option>
              <option>Competition</option>
              <option>Job</option>
              <option>Other</option>
            </select>
          </div>
          <div class="form-group">
            <label>Deadline</label>
            <input type="text" name="deadline" placeholder="e.g. July 15, 2025" />
          </div>
        </div>
        <div class="form-group">
          <label>Application Link *</label>
          <input type="url" name="link" required placeholder="https://..." />
        </div>
        <div class="form-group">
          <label>Brief Description</label>
          <textarea name="description" placeholder="Tell us a little about this opportunity..."></textarea>
        </div>
        <button type="submit" class="btn-primary" style="width:100%;justify-content:center;">Submit Opportunity →</button>
      </form>
    </div>
    <div class="popup-success" id="popup-success">
      <div class="success-check">
        <svg viewBox="0 0 52 52" class="checkmark-svg">
          <circle class="checkmark-circle" cx="26" cy="26" r="25" fill="none"/>
          <path class="checkmark-check" fill="none" d="M14.1 27.2l7.1 7.2 16.7-16.8"/>
        </svg>
      </div>
      <h3>Thank you! 🎉</h3>
      <p>We've received your submission and will review it shortly. If it's a good fit we'll publish it on DesignTechNews.</p>
    </div>
  </div>
</div>

