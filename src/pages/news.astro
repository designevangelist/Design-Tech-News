---
import { getCollection } from "astro:content";
const news = await getCollection("news");
---

<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Tech News – DesignTechNews</title>
  <meta name="description" content="Latest design tools, AI trends, startup ecosystem news, and tech company updates curated for Africa and global tech." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>

<nav class="mobile-nav" id="mobileNav">
  <button class="mobile-close" id="mobileClose">✕</button>
  <a href="/">Home</a>
  <a href="/opportunities">Opportunities</a>
  <a href="/jobs">Jobs</a>
  <a href="/news">News</a>
</nav>

<header>
  <div class="container">
    <nav>
      <a href="/" class="logo">
        <div class="logo-icon">DT</div>
        <span class="logo-text">Design<span>Tech</span>News</span>
      </a>
      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/opportunities">Opportunities</a></li>
        <li><a href="/jobs">Jobs</a></li>
        <li><a href="/news" class="active">News</a></li>
      </ul>
      <div class="nav-right">
        <button class="theme-toggle" id="themeToggle" aria-label="Toggle dark mode">🌙</button>
        <a href="/#newsletter" class="btn-subscribe">Subscribe</a>
        <button class="hamburger" id="hamburger"><span></span><span></span><span></span></button>
      </div>
    </nav>
  </div>
</header>

<main>
<section class="page-hero">
  <div class="container">
    <p class="section-label">📰 News</p>
    <h1>Design &amp; Tech News</h1>
    <p>New tools, AI trends, startup funding, and industry developments — curated daily for builders across Africa and beyond.</p>
  </div>
</section>

<section style="padding-top: 0;">
  <div class="container">
    <div class="search-bar">
      <span class="search-icon">🔍</span>
      <input type="text" id="searchInput" placeholder="Search news..." />
    </div>

    <div class="filter-bar">
      <button class="filter-btn active" data-filter="all">All</button>
      <button class="filter-btn" data-filter="ai">AI &amp; Design</button>
      <button class="filter-btn" data-filter="africa">Africa Tech</button>
      <button class="filter-btn" data-filter="tools">Tools</button>
      <button class="filter-btn" data-filter="startups">Startups</button>
    </div>

   <div class="card-grid">
  {news.map((article) => (
    <article class="news-card" data-category={article.data.category.toLowerCase()}>
      <div class="news-img news-img-1">
        <span class="news-img-icon">{article.data.icon ?? "📰"}</span>
        <span class="news-category">{article.data.category}</span>
      </div>
      <div class="news-body">
        <h3>{article.data.title}</h3>
        <p>{article.data.excerpt}</p>
        <div class="news-meta">
          <span class="date">{article.data.date}</span>
          <a href={`/news/${article.id}`} class="read-more">Read more →</a>
        </div>
      </div>
    </article>
  ))}
</div>


  </div>
</section>
</main>

<footer>
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <div class="logo">
          <div class="logo-icon">DT</div>
          <span class="logo-text">Design<span style="color:var(--blue)">Tech</span>News</span>
        </div>
        <p>Curated design and tech opportunities, jobs, and news across Africa and the global tech ecosystem.</p>
        <div class="social-links">
          <a href="#" class="social-link">𝕏</a>
          <a href="#" class="social-link">in</a>
          <a href="#" class="social-link">◻</a>
          <a href="#" class="social-link">▶</a>
        </div>
      </div>
      <div class="footer-col">
        <h5>Explore</h5>
        <ul class="footer-links">
          <li><a href="/opportunities">Opportunities</a></li>
          <li><a href="/jobs">Tech Jobs</a></li>
          <li><a href="/news">News</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h5>Topics</h5>
        <ul class="footer-links">
          <li><a href="/news">AI Design</a></li>
          <li><a href="/news">Africa Tech</a></li>
          <li><a href="/news">Design Tools</a></li>
          <li><a href="/news">Startup News</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h5>Company</h5>
        <ul class="footer-links">
          <li><a href="#">About Us</a></li>
          <li><a href="#">Submit News</a></li>
          <li><a href="#">Advertise</a></li>
          <li><a href="#">Contact</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© 2025 DesignTechNews. All rights reserved.</span>
      <span style="display:flex;gap:20px;"><a href="#">Privacy</a><a href="#">Terms</a></span>
    </div>
  </div>
</footer>

<script src="/script.js" is:inline></script>
</body>
</html>
