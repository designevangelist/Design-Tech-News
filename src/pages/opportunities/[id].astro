---
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const opportunities = await getCollection("opportunities");
  return opportunities.map((post) => ({
    params: { id: post.id },
    props: { post, allOpportunities: opportunities },
  }));
}

const { post, allOpportunities } = Astro.props;
const { Content } = await render(post);
const moreOpportunities = allOpportunities
  .filter((p) => p.id !== post.id)
  .slice(0, 3);
