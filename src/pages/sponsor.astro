<script src="/script.js" is:inline></script>
<script is:inline>
  // Prefill package select from card CTAs
  function prefillPackage(value) {
    setTimeout(() => {
      const sel = document.getElementById('package-select');
      if (sel) sel.value = value;
    }, 100);
  }

  // Sponsor form submission
  const sponsorForm = document.getElementById('sponsor-form');
  if (sponsorForm) {
    sponsorForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = document.getElementById('sponsor-submit-btn');
      btn.textContent = 'Sending...';
      btn.disabled = true;

      const formData = new FormData(sponsorForm);
      const response = await fetch(sponsorForm.action, {
        method: 'POST',
        body: formData,
        headers: { 'Accept': 'application/json' }
      });

      if (response.ok) {
        document.getElementById('sponsor-form-content').style.display = 'none';
        document.getElementById('sponsor-success').style.display = 'flex';
      } else {
        btn.textContent = 'Send Enquiry →';
        btn.disabled = false;
        alert('Something went wrong. Please email us directly at designevangelist1@gmail.com');
      }
    });
  }

  // FAQ accordion
  document.querySelectorAll('.faq-question').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.parentElement;
      const isOpen = item.classList.contains('open');
      document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));
      if (!isOpen) item.classList.add('open');
    });
  });
</script>

