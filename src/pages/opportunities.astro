<main>
<section class="page-hero">
  <div class="container">
    <p class="section-label">🎯 Opportunities</p>
    <h1>Design &amp; Tech Opportunities</h1>
    <p>Scholarships, fellowships, internships, accelerators, and competitions — curated for Africa and the global tech ecosystem.</p>
  </div>
</section>

<section style="padding-top: 0;">
  <div class="container">
    <div class="search-bar">
      <span class="search-icon">🔍</span>
      <input type="text" id="searchInput" placeholder="Search opportunities..." aria-label="Search opportunities" />
    </div>

    <div class="filter-bar">
      <button class="filter-btn active" data-filter="all">All</button>
      <button class="filter-btn" data-filter="scholarship">Scholarships</button>
      <button class="filter-btn" data-filter="fellowship">Fellowships</button>
      <button class="filter-btn" data-filter="internship">Internships</button>
      <button class="filter-btn" data-filter="accelerator">Accelerators</button>
      <button class="filter-btn" data-filter="competition">Competitions</button>
    </div>

    <div class="card-grid">

      <article class="card" data-category="fellowship">
        <span class="card-tag tag-fellowship">Fellowship</span>
        <h3>Google for Startups Africa Founders Fund</h3>
        <div class="card-meta">
          <span>🌍 Pan-Africa</span><span class="dot"></span><span>Google</span>
        </div>
        <p>Equity-free funding and technical support for early-stage African startups building with AI. Includes mentorship from Google engineers and access to Google Cloud credits.</p>
        <div class="card-footer">
          <span class="deadline urgent">⏰ Jul 15, 2025</span>
          <a href="post-template.html" class="btn-card">Learn More →</a>
        </div>
      </article>

      <article class="card" data-category="scholarship">
        <span class="card-tag tag-scholarship">Scholarship</span>
        <h3>Mastercard Foundation Scholars Program 2026</h3>
        <div class="card-meta">
          <span>🌍 Africa / Global</span><span class="dot"></span><span>Mastercard Foundation</span>
        </div>
        <p>Full scholarships for academically gifted yet economically disadvantaged young Africans to study at leading universities. Includes living stipend, flights, and mentorship.</p>
        <div class="card-footer">
          <span class="deadline">📅 Sep 30, 2025</span>
          <a href="post-template.html" class="btn-card">Learn More →</a>
        </div>
      </article>

      <article class="card" data-category="accelerator">
        <span class="card-tag tag-accelerator">Accelerator</span>
        <h3>Y Combinator Winter 2026 Batch</h3>
        <div class="card-meta">
          <span>🇺🇸 San Francisco / Remote</span><span class="dot"></span><span>Y Combinator</span>
        </div>
        <p>The world's most prestigious startup accelerator offering $500K for 7% equity. Open to global founders. 3-month intensive program with weekly dinners and Demo Day.</p>
        <div class="card-footer">
          <span class="deadline">📅 Oct 1, 2025</span>
          <a href="post-template.html" class="btn-card">Learn More →</a>
        </div>
      </article>

      <article class="card" data-category="internship">
        <span class="card-tag tag-internship">Internship</span>
        <h3>Meta Product Design Internship 2026</h3>
        <div class="card-meta">
          <span>🇺🇸 Remote / Menlo Park</span><span class="dot"></span><span>Meta</span>
        </div>
        <p>12-week paid internship for design students and early career designers. Work on real products used by billions of people. Open to international students with visa sponsorship.</p>
        <div class="card-footer">
          <span class="deadline">📅 Nov 15, 2025</span>
          <a href="post-template.html" class="btn-card">Learn More →</a>
        </div>
      </article>

      <article class="card" data-category="competition">
        <span class="card-tag tag-competition">Competition</span>
        <h3>Adobe Design Achievement Awards 2025</h3>
        <div class="card-meta">
          <span>🌐 Global</span><span class="dot"></span><span>Adobe</span>
        </div>
        <p>Celebrating student creativity across graphic design, illustration, motion, UI/UX, and photography. Cash prizes, Adobe Creative Cloud licenses, and career opportunities.</p>
        <div class="card-footer">
          <span class="deadline urgent">⏰ Aug 20, 2025</span>
          <a href="post-template.html" class="btn-card">Learn More →</a>
        </div>
      </article>

      <article class="card" data-category="fellowship">
        <span class="card-tag tag-fellowship">Fellowship</span>
        <h3>Mandela Washington Fellowship for Young African Leaders</h3>
        <div class="card-meta">
          <span>🇺🇸 USA</span><span class="dot"></span><span>U.S. Department of State</span>
        </div>
        <p>6-week leadership institute at a U.S. university plus an optional internship in Washington, D.C. for young African leaders ages 25–35 making change in their communities.</p>
        <div class="card-footer">
          <span class="deadline">📅 Oct 31, 2025</span>
          <a href="post-template.html" class="btn-card">Learn More →</a>
        </div>
      </article>

      <article class="card" data-category="scholarship">
        <span class="card-tag tag-scholarship">Scholarship</span>
        <h3>ALX Africa Tech Scholarship</h3>
        <div class="card-meta">
          <span>🌍 Africa</span><span class="dot"></span><span>ALX Africa</span>
        </div>
        <p>Full-scholarship program in software engineering, data science, and UI/UX design for young Africans. 12-month intensive program with job placement support.</p>
        <div class="card-footer">
          <span class="deadline">📅 Rolling Admissions</span>
          <a href="post-template.html" class="btn-card">Learn More →</a>
        </div>
      </article>

      <article class="card" data-category="accelerator">
        <span class="card-tag tag-accelerator">Accelerator</span>
        <h3>Techstars Lagos Accelerator Program</h3>
        <div class="card-meta">
          <span>🇳🇬 Lagos, Nigeria</span><span class="dot"></span><span>Techstars</span>
        </div>
        <p>3-month mentor-driven accelerator for early-stage startups in West Africa. $20K investment, access to a global network of 10,000+ mentors, and investors demo day.</p>
        <div class="card-footer">
          <span class="deadline">📅 Aug 1, 2025</span>
          <a href="post-template.html" class="btn-card">Learn More →</a>
        </div>
      </article>

      <article class="card" data-category="internship">
        <span class="card-tag tag-internship">Internship</span>
        <h3>Andela Engineering Internship</h3>
        <div class="card-meta">
          <span>🌍 Remote / Africa</span><span class="dot"></span><span>Andela</span>
        </div>
        <p>Paid remote engineering internship for African developers. Work with global tech companies on real projects. Frontend, backend, and mobile tracks available.</p>
        <div class="card-footer">
          <span class="deadline">📅 Rolling</span>
          <a href="post-template.html" class="btn-card">Learn More →</a>
        </div>
      </article>

    </div>
  </div>
</section>

<section id="newsletter" style="padding-top: 0;">
  <div class="container">
    <div class="newsletter-section">
      <div class="newsletter-inner">
        <p class="section-label">📬 Never miss an opportunity</p>
        <h2>Get weekly opportunity alerts</h2>
        <p>We curate the best opportunities every week and send them directly to your inbox. 12,000+ professionals trust DesignTechNews.</p>
        <form class="newsletter-form" onsubmit="return false">
          <input type="email" placeholder="Your email address" required />
          <button type="submit">Subscribe Free</button>
        </form>
        <p class="newsletter-trust">🔒 No spam. Unsubscribe anytime.</p>
      </div>
    </div>
  </div>
</section>
