---
import { getCollection } from "astro:content";
const opportunities = await getCollection("opportunities");
---

<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Opportunities – DesignTechNews</title>
  <meta name="description" content="Browse scholarships, fellowships, internships, accelerators, and competitions for designers and tech professionals." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="/styles.css" />
<link rel="icon" type="image/x-icon" href="/favicon.ico" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />
</head>
<body>

<nav class="mobile-nav" id="mobileNav">
  <button class="mobile-close" id="mobileClose">✕</button>
  <a href="/">Home</a>
  <a href="/opportunities">Opportunities</a>
  <a href="/jobs">Jobs</a>
  <a href="/news">News</a>
  <a href="/about">About</a>
</nav>

<header>
  <div class="container">
    <nav>
      <a href="/" class="logo">
  <img src="/images/light-logo.png" alt="DesignTechNews" class="logo-img logo-light" />
  <img src="/images/dark-logo.png" alt="DesignTechNews" class="logo-img logo-dark" />
</a>
      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/opportunities" class="active">Opportunities</a></li>
        <li><a href="/jobs">Jobs</a></li>
        <li><a href="/news">News</a></li>
        <li><a href="/about">About</a></li>
      </ul>
      <div class="nav-right">
        <button class="theme-toggle" id="themeToggle" aria-label="Toggle dark mode">🌙</button>
        <a href="/about?submit=true" class="btn-subscribe">Submit Opportunity</a>
        <button class="hamburger" id="hamburger"><span></span><span></span><span></span></button>
      </div>
    </nav>
  </div>
</header>

  <main>
    <section class="page-hero">
      <div class="container">
        <p class="section-label">🎯 Opportunities</p>
        <h1>Design &amp; Tech Opportunities</h1>
        <p>Scholarships, fellowships, internships, accelerators — curated for Africa and beyond.</p>
      </div>
    </section>

    <section style="padding-top: 0;">
      <div class="container">
        <div class="card-grid">
          {opportunities.map((post) => (
            <article class="card">
              <span class={`card-tag tag-${post.data.type.toLowerCase()}`}>
                {post.data.type}
              </span>
              <h3>{post.data.title}</h3>
              <div class="card-meta">
                <span>🌍 {post.data.location}</span>
              </div>
              <p>{post.data.description}</p>
              <div class="card-footer">
                <span class="deadline">📅 {post.data.deadline}</span>
               <a href={`/opportunities/${post.id}`} class="btn-card">
                  Learn More →
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>

<!-- NEWSLETTER CTA -->
<section style="padding: 48px 0;">
  <div class="container">
    <div class="newsletter-section" style="padding: 40px 48px;">
      <div class="newsletter-layout">
        <div class="newsletter-inner">
          <p class="section-label">📬 Never miss an update</p>
          <h2 style="font-size:clamp(1.5rem,2.5vw,2rem);">Get weekly design & tech opportunities</h2>
          <form class="newsletter-form newsletter-sub" style="position:relative;margin-top:20px;">
            <input type="email" name="EMAIL" placeholder="Enter your email address" required aria-label="Email address" />
            <div style="position:absolute;left:-5000px;" aria-hidden="true">
              <input type="text" name="b_3b667d867a0c7d77bc2de09db_3d67b5db75" tabindex="-1" value="" />
            </div>
            <button type="submit">Subscribe Free</button>
          </form>
          <p class="newsletter-trust">🔒 No spam. Unsubscribe anytime.</p>
        </div>
        <div class="newsletter-image newsletter-sub-success" style="display:none;flex-direction:column;align-items:center;justify-content:center;text-align:center;gap:12px;">
          <div class="success-check">
            <svg viewBox="0 0 52 52" class="checkmark-svg">
              <circle class="checkmark-circle" cx="26" cy="26" r="25" fill="none"/>
              <path class="checkmark-check" fill="none" d="M14.1 27.2l7.1 7.2 16.7-16.8"/>
            </svg>
          </div>
          <p style="color:white;font-weight:700;font-size:1.1rem;margin:0;">You're in! 🎉</p>
          <p style="color:rgba(255,255,255,0.65);font-size:0.9rem;margin:0;">Check your inbox for a confirmation email.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<footer>
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
  <a href="/" class="logo">
<img src="/images/dark-logo.png" alt="DesignTechNews" class="logo-img" />
  </a>
  <p>Discover design and technology opportunities across Africa and the global tech ecosystem.</p>
 <div class="social-links">
  <a href="#" class="social-link" aria-label="X (Twitter)">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
