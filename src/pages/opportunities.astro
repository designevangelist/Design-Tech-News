---
import { getCollection } from "astro:content";
const opportunities = await getCollection("opportunities");
---

<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Opportunities – DesignTechNews</title>
  <meta name="description" content="Browse scholarships, fellowships, internships, accelerators, and competitions for designers and tech professionals." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>

<nav class="mobile-nav" id="mobileNav">
  <button class="mobile-close" id="mobileClose">✕</button>
  <a href="/">Home</a>
  <a href="/opportunities">Opportunities</a>
  <a href="/jobs">Jobs</a>
  <a href="/news">News</a>
</nav>

<header>
  <div class="container">
    <nav>
      <a href="/" class="logo">
        <div class="logo-icon">DT</div>
        <span class="logo-text">Design<span>Tech</span>News</span>
      </a>
      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/opportunities" class="active">Opportunities</a></li>
        <li><a href="/jobs">Jobs</a></li>
        <li><a href="/news">News</a></li>
      </ul>
      <div class="nav-right">
        <button class="theme-toggle" id="themeToggle" aria-label="Toggle dark mode">🌙</button>
        <a href="/#newsletter" class="btn-subscribe">Subscribe</a>
        <button class="hamburger" id="hamburger"><span></span><span></span><span></span></button>
      </div>
    </nav>
  </div>
</header>

  <main>
    <section class="page-hero">
      <div class="container">
        <p class="section-label">🎯 Opportunities</p>
        <h1>Design &amp; Tech Opportunities</h1>
        <p>Scholarships, fellowships, internships, accelerators — curated for Africa and beyond.</p>
      </div>
    </section>

    <section style="padding-top: 0;">
      <div class="container">
        <div class="card-grid">
          {opportunities.map((post) => (
            <article class="card">
              <span class={`card-tag tag-${post.data.type.toLowerCase()}`}>
                {post.data.type}
              </span>
              <h3>{post.data.title}</h3>
              <div class="card-meta">
                <span>🌍 {post.data.location}</span>
              </div>
              <p>{post.data.description}</p>
              <div class="card-footer">
                <span class="deadline">📅 {post.data.deadline}</span>
               <a href={`/opportunities/${post.id}`} class="btn-card">
                  Learn More →
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>

<footer>
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <div class="logo">
          <div class="logo-icon">DT</div>
          <span class="logo-text">Design<span style="color:var(--blue)">Tech</span>News</span>
        </div>
        <p>Discover design and technology opportunities across Africa and the global tech ecosystem.</p>
        <div class="social-links">
          <a href="#" class="social-link">𝕏</a>
          <a href="#" class="social-link">in</a>
          <a href="#" class="social-link">◻</a>
          <a href="#" class="social-link">▶</a>
        </div>
      </div>
      <div class="footer-col">
        <h5>Explore</h5>
        <ul class="footer-links">
          <li><a href="/opportunities">Opportunities</a></li>
          <li><a href="/jobs">Tech Jobs</a></li>
          <li><a href="/news">News</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h5>Categories</h5>
        <ul class="footer-links">
          <li><a href="/opportunities">Scholarships</a></li>
          <li><a href="/opportunities">Fellowships</a></li>
          <li><a href="/opportunities">Accelerators</a></li>
          <li><a href="/opportunities">Competitions</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h5>Company</h5>
        <ul class="footer-links">
          <li><a href="#">About Us</a></li>
          <li><a href="#">Submit Opportunity</a></li>
          <li><a href="#">Advertise</a></li>
          <li><a href="#">Contact</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© 2025 DesignTechNews. All rights reserved.</span>
      <span style="display:flex;gap:20px;"><a href="#">Privacy</a><a href="#">Terms</a></span>
    </div>
  </div>
</footer>

<script src="/script.js" is:inline></script>
</body>
</html>
