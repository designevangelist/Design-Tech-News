  <style>
    /* ── Legal page layout (same as privacy.astro) ── */
    .legal-hero {
      padding: 72px 0 48px;
      border-bottom: 1px solid var(--border);
      position: relative;
      overflow: hidden;
    }

    .legal-hero::before {
      content: '';
      position: absolute;
      top: -160px; right: -160px;
      width: 480px; height: 480px;
      background: radial-gradient(ellipse, rgba(34,197,94,0.06) 0%, transparent 65%);
      pointer-events: none;
    }

    .legal-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 5px 14px;
      background: rgba(34,197,94,0.08);
      border: 1px solid rgba(34,197,94,0.2);
      border-radius: 100px;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: var(--green-dark);
      margin-bottom: 20px;
    }

    [data-theme="dark"] .legal-eyebrow {
      color: var(--green);
    }

    .legal-hero h1 {
      font-size: clamp(2rem, 4vw, 3rem);
      font-weight: 800;
      letter-spacing: -1.5px;
      margin-bottom: 16px;
    }

    .legal-hero-meta {
      display: flex;
      align-items: center;
      gap: 24px;
      flex-wrap: wrap;
      font-size: 13px;
      color: var(--text-muted);
      font-weight: 500;
    }

    /* ── Two-column layout ── */
    .legal-layout {
      display: grid;
      grid-template-columns: 220px 1fr;
      gap: 64px;
      padding: 64px 0 96px;
      align-items: start;
    }

    /* ── Sticky TOC sidebar ── */
    .legal-toc {
      position: sticky;
      top: 88px;
    }

    .legal-toc h6 {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: 16px;
    }

    .toc-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .toc-list a {
      display: block;
      padding: 7px 12px;
      border-radius: 8px;
      font-size: 13px;
      font-weight: 500;
      color: var(--text-muted);
      transition: all 0.2s;
      border-left: 2px solid transparent;
      margin-left: -2px;
    }

    .toc-list a:hover {
      color: var(--green-dark);
      background: rgba(34,197,94,0.07);
      border-left-color: var(--green);
      padding-left: 16px;
    }

    [data-theme="dark"] .toc-list a:hover {
      color: var(--green);
    }

    /* ── Legal content ── */
    .legal-content { min-width: 0; }

    .legal-section {
      padding: 40px 0;
      border-bottom: 1px solid var(--border);
    }

    .legal-section:first-child { padding-top: 0; }
    .legal-section:last-child { border-bottom: none; }

    .legal-section h2 {
      font-size: 1.3rem;
      font-weight: 800;
      letter-spacing: -0.4px;
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .legal-section h2 .section-num {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 28px;
      height: 28px;
      background: rgba(34,197,94,0.1);
      color: var(--green-dark);
      border-radius: 8px;
      font-size: 12px;
      font-weight: 800;
      flex-shrink: 0;
    }

    [data-theme="dark"] .legal-section h2 .section-num {
      color: var(--green);
    }

    .legal-section p {
      font-size: 15px;
      color: var(--text-mid);
      line-height: 1.85;
      margin-bottom: 16px;
    }

    .legal-section p:last-child { margin-bottom: 0; }

    .legal-section h3 {
      font-size: 1rem;
      font-weight: 700;
      color: var(--text);
      margin: 24px 0 10px;
    }

    .legal-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 10px;
      margin: 12px 0 20px;
      padding: 0;
    }

    .legal-list li {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      font-size: 15px;
      color: var(--text-mid);
      line-height: 1.7;
    }

    .legal-list li::before {
      content: '→';
      color: var(--green-dark);
      font-weight: 700;
      flex-shrink: 0;
      margin-top: 2px;
      font-size: 12px;
    }

    [data-theme="dark"] .legal-list li::before {
      color: var(--green);
    }

    .legal-highlight {
      background: rgba(34,197,94,0.05);
      border: 1px solid rgba(34,197,94,0.15);
      border-left: 3px solid var(--green);
      border-radius: 0 10px 10px 0;
      padding: 18px 20px;
      margin: 20px 0;
      font-size: 14px;
      color: var(--text-mid);
      line-height: 1.75;
    }

    [data-theme="dark"] .legal-highlight {
      background: rgba(34,197,94,0.06);
      border-color: rgba(34,197,94,0.15);
    }

    .legal-warning {
      background: rgba(239,68,68,0.05);
      border: 1px solid rgba(239,68,68,0.15);
      border-left: 3px solid #EF4444;
      border-radius: 0 10px 10px 0;
      padding: 18px 20px;
      margin: 20px 0;
      font-size: 14px;
      color: var(--text-mid);
      line-height: 1.75;
    }

    .legal-contact-box {
      background: linear-gradient(135deg, rgba(34,197,94,0.06) 0%, rgba(37,99,235,0.04) 100%);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 28px;
      margin-top: 16px;
    }

    .legal-contact-box h4 {
      font-size: 1rem;
      font-weight: 700;
      margin-bottom: 10px;
    }

    .legal-contact-box p { margin-bottom: 8px !important; }

    .legal-contact-box a {
      color: var(--blue);
      font-weight: 600;
      transition: opacity 0.2s;
    }

    .legal-contact-box a:hover { opacity: 0.75; }

    /* ── Responsive ── */
    @media (max-width: 768px) {
      .legal-layout {
        grid-template-columns: 1fr;
        gap: 0;
        padding: 40px 0 64px;
      }

      .legal-toc {
        position: static;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 20px;
        margin-bottom: 40px;
      }
    }
  </style>
</head>
