---
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const news = await getCollection("news");
  return news.map((article) => ({
    params: { id: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);
---

<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{article.data.title} – DesignTechNews</title>
  <meta name="description" content={article.data.excerpt} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="/styles.css" />
  <style>
    html, body { overflow-x: hidden; overflow-y: auto; height: auto; }
    main { min-height: 100vh; }
    .post-content h2 { font-size: 1.35rem; font-weight: 700; margin: 32px 0 14px; letter-spacing: -0.3px; }
    .post-content p { color: var(--text-mid); line-height: 1.8; font-size: 1.05rem; margin-bottom: 16px; }
    .post-content ul { list-style: none; display: flex; flex-direction: column; gap: 10px; margin-bottom: 16px; }
    .post-content ul li { display: flex; align-items: flex-start; gap: 10px; font-size: 1rem; color: var(--text-mid); line-height: 1.6; }
    .post-content ul li::before { content: '→'; color: var(--blue); font-weight: 700; flex-shrink: 0; margin-top: 2px; }
    .post-content strong { color: var(--text); font-weight: 700; }
  </style>
</head>
<body>

<nav class="mobile-nav" id="mobileNav">
  <button class="mobile-close" id="mobileClose">✕</button>
  <a href="/">Home</a>
  <a href="/opportunities">Opportunities</a>
  <a href="/jobs">Jobs</a>
  <a href="/news">News</a>
</nav>

<header>
  <div class="container">
    <nav>
      <a href="/" class="logo">
        <div class="logo-icon">DT</div>
        <span class="logo-text">Design<span>Tech</span>News</span>
      </a>
      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/opportunities">Opportunities</a></li>
        <li><a href="/jobs">Jobs</a></li>
        <li><a href="/news" class="active">News</a></li>
      </ul>
      <div class="nav-right">
        <button class="theme-toggle" id="themeToggle" aria-label="Toggle dark mode">🌙</button>
        <a href="/#newsletter" class="btn-subscribe">Subscribe</a>
        <button class="hamburger" id="hamburger"><span></span><span></span><span></span></button>
      </div>
    </nav>
  </div>
</header>

<main>
<div class="container">
  <div class="post-wrapper">

    <!-- BREADCRUMB -->
    <nav style="padding:24px 0 0;font-size:14px;color:var(--text-muted);display:flex;align-items:center;gap:8px;">
      <a href="/" style="color:var(--text-muted);transition:color 0.2s;" onmouseover="this.style.color='var(--blue)'" onmouseout="this.style.color='var(--text-muted)'">Home</a>
      <span>›</span>
      <a href="/news" style="color:var(--text-muted);transition:color 0.2s;" onmouseover="this.style.color='var(--blue)'" onmouseout="this.style.color='var(--text-muted)'">News</a>
      <span>›</span>
      <span style="color:var(--text);">{article.data.title}</span>
    </nav>

    <!-- POST HEADER -->
    <header class="post-header">
      <div class="post-meta">
        <span class="card-tag tag-news">{article.data.category}</span>
        <span class="meta-item">📅 {article.data.date}</span>
      </div>
      <h1>{article.data.title}</h1>
      <p style="font-size:1.1rem;color:var(--text-muted);line-height:1.7;max-width:640px;">{article.data.excerpt}</p>
    </header>

    <div class="divider"></div>

    <!-- MARKDOWN CONTENT -->
    <div class="post-content">
      <Content />
    </div>

    <div class="divider"></div>

    <!-- SHARE -->
    <div class="share-section">
      <h4>Share this article</h4>
      <div class="share-buttons">
        <button class="share-btn" onclick={`window.open('https://twitter.com/intent/tweet?url='+encodeURIComponent(window.location.href))`}>𝕏 Share on X</button>
        <button class="share-btn" onclick={`window.open('https://www.linkedin.com/shareArticle?mini=true&url='+encodeURIComponent(window.location.href))`}>in LinkedIn</button>
        <button class="share-btn" onclick="navigator.clipboard.writeText(window.location.href).then(()=>{this.textContent='✓ Copied!'})">🔗 Copy Link</button>
      </div>
    </div>

    <div class="divider"></div>

    <div style="margin-bottom:72px;">
      <a href="/news" style="color:var(--blue);font-weight:600;font-size:14px;">← Back to all news</a>
    </div>

  </div>
</div>
</main>

