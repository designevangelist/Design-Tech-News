---
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const jobs = await getCollection("jobs");
  return jobs.map((job) => ({
    params: { id: job.id },
    props: { job },
  }));
}

const { job } = Astro.props;
const { Content } = await render(job);
---

<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{job.data.title} at {job.data.company} – DesignTechNews</title>
  <meta name="description" content={`${job.data.title} at ${job.data.company} — ${job.data.location}`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="/styles.css" />
  <style>
    html, body { overflow-x: hidden; overflow-y: auto; height: auto; }
    main { min-height: 100vh; }
    .post-content h2 { font-size: 1.35rem; font-weight: 700; margin: 32px 0 14px; letter-spacing: -0.3px; }
    .post-content p { color: var(--text-mid); line-height: 1.8; font-size: 1.05rem; margin-bottom: 16px; }
    .post-content ul { list-style: none; display: flex; flex-direction: column; gap: 10px; margin-bottom: 16px; }
    .post-content ul li { display: flex; align-items: flex-start; gap: 10px; font-size: 1rem; color: var(--text-mid); line-height: 1.6; }
    .post-content ul li::before { content: '→'; color: var(--blue); font-weight: 700; flex-shrink: 0; margin-top: 2px; }
    .post-content strong { color: var(--text); font-weight: 700; }
  </style>
</head>
<body>

<nav class="mobile-nav" id="mobileNav">
  <button class="mobile-close" id="mobileClose">✕</button>
  <a href="/">Home</a>
  <a href="/opportunities">Opportunities</a>
  <a href="/jobs">Jobs</a>
  <a href="/news">News</a>
</nav>

<header>
  <div class="container">
    <nav>
      <a href="/" class="logo">
        <div class="logo-icon">DT</div>
        <span class="logo-text">Design<span>Tech</span>News</span>
      </a>
      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/opportunities">Opportunities</a></li>
        <li><a href="/jobs" class="active">Jobs</a></li>
        <li><a href="/news">News</a></li>
      </ul>
      <div class="nav-right">
        <button class="theme-toggle" id="themeToggle" aria-label="Toggle dark mode">🌙</button>
        <a href="/#newsletter" class="btn-subscribe">Subscribe</a>
        <button class="hamburger" id="hamburger"><span></span><span></span><span></span></button>
      </div>
    </nav>
  </div>
</header>

<main>
<div class="container">
  <div class="post-wrapper">

    <!-- BREADCRUMB -->
    <nav style="padding:24px 0 0;font-size:14px;color:var(--text-muted);display:flex;align-items:center;gap:8px;" aria-label="Breadcrumb">
      <a href="/" style="color:var(--text-muted);transition:color 0.2s;" onmouseover="this.style.color='var(--blue)'" onmouseout="this.style.color='var(--text-muted)'">Home</a>
      <span>›</span>
      <a href="/jobs" style="color:var(--text-muted);transition:color 0.2s;" onmouseover="this.style.color='var(--blue)'" onmouseout="this.style.color='var(--text-muted)'">Jobs</a>
      <span>›</span>
      <span style="color:var(--text);">{job.data.title}</span>
    </nav>

    <!-- POST HEADER -->
    <header class="post-header">
      <div class="post-meta">
        <span class="card-tag tag-fulltime">{job.data.jobType}</span>
        <span class="meta-item">📍 {job.data.location}</span>
      </div>
      <h1>{job.data.title}</h1>
      <p style="font-size:1.1rem;color:var(--text-muted);line-height:1.7;max-width:640px;">
        {job.data.company} · {job.data.location}
      </p>
    </header>

    <!-- KEY INFO STRIP -->
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:16px;margin-bottom:40px;">
      <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:12px;padding:18px 20px;">
        <p style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--text-muted);margin-bottom:6px;">Company</p>
        <p style="font-weight:700;font-size:15px;">{job.data.company}</p>
      </div>
      <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:12px;padding:18px 20px;">
        <p style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--text-muted);margin-bottom:6px;">Location</p>
        <p style="font-weight:700;font-size:15px;">{job.data.location}</p>
      </div>
      <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:12px;padding:18px 20px;">
        <p style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--text-muted);margin-bottom:6px;">Job Type</p>
        <p style="font-weight:700;font-size:15px;">{job.data.jobType}</p>
      </div>
      <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:12px;padding:18px 20px;">
        <p style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--text-muted);margin-bottom:6px;">Salary</p>
        <p style="font-weight:700;font-size:15px;">{job.data.salary ?? "Not disclosed"}</p>
      </div>
    </div>

    <div class="divider"></div>

    <!-- MARKDOWN CONTENT -->
    <div class="post-content">
      <Content />
    </div>

    <div class="divider"></div>

    <!-- APPLY CTA -->
    {job.data.link && (
      <div class="cta-box">
        <h3>Ready to Apply?</h3>
        <p>Visit {job.data.company}'s careers page to submit your application.</p>
        <a href={job.data.link} target="_blank" rel="noopener noreferrer" class="btn-primary" style="display:inline-flex;margin:0 auto;">
          Apply at {job.data.company} →
        </a>
      </div>
    )}

    <!-- SHARE -->
    <div class="divider"></div>
    <div class="share-section">
      <h4>Share this job</h4>
      <div class="share-buttons">
        <button class="share-btn" onclick={`window.open('https://twitter.com/intent/tweet?url='+encodeURIComponent(window.location.href))`}>𝕏 Share on X</button>
        <button class="share-btn" onclick={`window.open('https://www.linkedin.com/shareArticle?mini=true&url='+encodeURIComponent(window.location.href))`}>in LinkedIn</button>
        <button class="share-btn" onclick="navigator.clipboard.writeText(window.location.href).then(()=>{this.textContent='✓ Copied!'})">🔗 Copy Link</button>
      </div>
    </div>

    <div class="divider"></div>

    <!-- BACK LINK -->
    <div style="margin-bottom:72px;">
      <h3 style="font-size:1.3rem;margin-bottom:24px;">More Jobs</h3>
      <a href="/jobs" style="color:var(--blue);font-weight:600;font-size:14px;">← Back to all jobs</a>
    </div>

  </div>
</div>
</main>

<footer>
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <div class="logo">
          <div class="logo-icon">DT</div>
          <span class="logo-text">Design<span style="color:var(--blue)">Tech</span>News</span>
        </div>
        <p>Curated design and tech opportunities, jobs, and news across Africa and the global tech ecosystem.</p>
        <div class="social-links">
          <a href="#" class="social-link">𝕏</a>
          <a href="#" class="social-link">in</a>
          <a href="#" class="social-link">◻</a>
          <a href="#" class="social-link">▶</a>
        </div>
      </div>
      <div class="footer-col">
        <h5>Explore</h5>
        <ul class="footer-links">
          <li><a href="/opportunities">Opportunities</a></li>
          <li><a href="/jobs">Tech Jobs</a></li>
          <li><a href="/news">News</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h5>Job Types</h5>
        <ul class="footer-links">
          <li><a href="/jobs">Design Jobs</a></li>
          <li><a href="/jobs">Engineering Jobs</a></li>
          <li><a href="/jobs">Product Jobs</a></li>
          <li><a href="/jobs">Remote Jobs</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h5>Company</h5>
        <ul class="footer-links">
          <li><a href="#">About Us</a></li>
          <li><a href="#">Post a Job</a></li>
          <li><a href="#">Advertise</a></li>
          <li><a href="#">Contact</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© 2025 DesignTechNews. All rights reserved.</span>
      <span style="display:flex;gap:20px;"><a href="#">Privacy</a><a href="#">Terms</a></span>
    </div>
  </div>
</footer>

<script src="/script.js" is:inline></script>
</body>
</html>