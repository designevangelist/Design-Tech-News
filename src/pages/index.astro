---
import { getCollection } from "astro:content";

const allOpportunities = await getCollection("opportunities");
const allJobs = await getCollection("jobs");
const allNews = await getCollection("news");

const opportunities = allOpportunities.slice(0, 3);
const jobs = allJobs.slice(0, 6);
const news = allNews.slice(0, 3);
---

<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>DesignTechNews – Design &amp; Technology Opportunities, Jobs &amp; News</title>
  <meta name="description" content="The central place to discover design and technology opportunities, jobs, and industry news across Africa and the global tech ecosystem." />
  <meta name="keywords" content="design opportunities, tech jobs, Africa tech, scholarships, fellowships, tech news" />
  <meta property="og:title" content="DesignTechNews" />
  <meta property="og:description" content="Design & Technology opportunities, jobs, and news across Africa and beyond." />
  <meta property="og:type" content="website" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="/styles.css" />
<link rel="icon" type="image/x-icon" href="/favicon.ico" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />
</head>
<body>

<!-- MOBILE NAV OVERLAY -->
<nav class="mobile-nav" id="mobileNav" role="navigation" aria-label="Mobile navigation">
  <button class="mobile-close" id="mobileClose" aria-label="Close menu">✕</button>
  <a href="/">Home</a>
  <a href="/opportunities">Opportunities</a>
  <a href="/jobs">Jobs</a>
  <a href="/news">News</a>
</nav>

<!-- HEADER -->
<header>
  <div class="container">
    <nav>
      <a href="/" class="logo">
  <img src="/images/light-logo.png" alt="DesignTechNews" class="logo-img logo-light" />
  <img src="/images/dark-logo.png" alt="DesignTechNews" class="logo-img logo-dark" />
</a>
      <ul class="nav-links" role="list">
        <li><a href="/" class="active">Home</a></li>
        <li><a href="/opportunities">Opportunities</a></li>
        <li><a href="/jobs">Jobs</a></li>
        <li><a href="/news">News</a></li>
      </ul>
      <div class="nav-right">
        <button class="theme-toggle" id="themeToggle" aria-label="Toggle dark mode">🌙</button>
        <a href="#newsletter" class="btn-subscribe">Subscribe</a>
        <button class="hamburger" id="hamburger" aria-label="Open menu">
          <span></span><span></span><span></span>
        </button>
      </div>
    </nav>
  </div>
</header>

<!-- HERO -->
<main>
<section class="hero">
  <div class="container">
    <div style="text-align:center;">
      <div class="hero-badge" style="display:inline-flex;">🌍 Africa + Global Tech Ecosystem</div>
      
      <h1 style="margin-left:auto; margin-right:auto; font-size:clamp(2.4rem,4.5vw,3.5rem);">
        Your Hub for <span class="accent">Design</span> &amp;<br>
        <span class="accent-green">Tech</span> Opportunities
      </h1>


      
      <p style="margin-left:auto;margin-right:auto;">Discover scholarships, fellowships, top tech jobs, and industry news — curated for designers, developers, and builders across Africa and the world.</p>
      <div class="hero-actions" style="justify-content:center;">
        <a href="/opportunities" class="btn-primary">Browse Opportunities →</a>
        <a href="/jobs" class="btn-secondary">View Tech Jobs</a>
      </div>
    </div>
    <div class="hero-stats" style="justify-content:center;">
      <div class="stat">
        <span class="stat-num">200+</span>
        <span class="stat-label">Active Opportunities</span>
      </div>
      <div class="stat">
        <span class="stat-num">150+</span>
        <span class="stat-label">Tech Jobs Listed</span>
      </div>
      <div class="stat">
        <span class="stat-num">50+</span>
        <span class="stat-label">Countries Covered</span>
      </div>
      <div class="stat">
        <span class="stat-num">12K+</span>
        <span class="stat-label">Monthly Readers</span>
      </div>
    </div>
  </div>
</section>

<!-- FEATURED OPPORTUNITIES -->
<section>
  <div class="container">
    <div class="section-header">
      <div>
        <p class="section-label">🎯 Featured</p>
        <h2 class="section-title">Top Opportunities</h2>
      </div>
      <a href="/opportunities" class="view-all">View all →</a>
    </div>
    <div class="card-grid">
      {opportunities.map((post) => (
        <article class="card fade-up" data-category={post.data.type.toLowerCase()}>
          <span class={`card-tag tag-${post.data.type.toLowerCase()}`}>{post.data.type}</span>
          <h3>{post.data.title}</h3>
          <div class="card-meta">
            <span>🌍 {post.data.location}</span>
          </div>
          <p>{post.data.description}</p>
          <div class="card-footer">
            <span class="deadline">📅 {post.data.deadline}</span>
            <a href={`/opportunities/${post.id}`} class="btn-card">Learn More →</a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- FEATURED JOBS -->
<section class="bg-subtle">
  <div class="container">
    <div class="section-header">
      <div>
        <p class="section-label">💼 Hiring Now</p>
        <h2 class="section-title">Latest Tech Jobs</h2>
      </div>
      <a href="/jobs" class="view-all">View all jobs →</a>
    </div>

    <div class="card-grid">
  {jobs.map((job) => (
    <article class="job-card-v" data-category={job.data.jobType.toLowerCase()}>
      <div class="company-logo">
        {job.data.company.slice(0, 2).toUpperCase()}
      </div>
      <div class="job-info">
        <h4>{job.data.title}</h4>
        <p class="company">{job.data.company} · {job.data.location}</p>
        <div class="job-tags" style="margin: 8px 0;">
          <span class="card-tag tag-remote" style="margin:0">
            {job.data.location.toLowerCase().includes("remote") ? "Remote" : "On-site"}
          </span>
          <span class="card-tag tag-fulltime" style="margin:0">{job.data.jobType}</span>
        </div>
        <div style="display:flex;align-items:center;justify-content:space-between;margin-top:12px;">
          {job.data.salary && (
            <span style="font-size:13px;color:var(--text-muted);font-weight:600;">{job.data.salary}</span>
          )}
          <a href={`/jobs/${job.id}`} class="btn-card">Apply →</a>
        </div>
      </div>
    </article>
  ))}
</div>
  </div>
</section>

<!-- LATEST NEWS -->
<section>
  <div class="container">
    <div class="section-header">
      <div>
        <p class="section-label">📰 Latest</p>
        <h2 class="section-title">Industry News</h2>
      </div>
      <a href="/news" class="view-all">More news →</a>
    </div>
    <div class="card-grid">
      {news.map((article) => (
        <article class="news-card fade-up">
          <div class="news-img news-img-1">
  {article.data.image ? (
    <>
      <img src={article.data.image} alt={article.data.title} style="width:100%;height:100%;object-fit:cover;position:absolute;top:0;left:0;" />
      <span class="news-category" style="position:relative;z-index:1;">{article.data.category}</span>
    </>
  ) : (
    <>
      <span class="news-img-icon">{article.data.icon ?? "📰"}</span>
      <span class="news-category">{article.data.category}</span>
    </>
  )}
</div>
          <div class="news-body">
            <h3>{article.data.title}</h3>
            <p>{article.data.excerpt}</p>
            <div class="news-meta">
              <span class="date">{article.data.date}</span>
              <a href={`/news/${article.id}`} class="read-more">Read more →</a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- NEWSLETTER -->
<section id="newsletter">
  <div class="container">
    <div class="newsletter-section">
      <div class="newsletter-layout">
        <div class="newsletter-inner">
          <p class="section-label">📬 Newsletter</p>
          <h2>Stay ahead of the curve</h2>
          <p>Get the best design and tech opportunities, jobs, and news delivered to your inbox every week. Join 12,000+ professionals.</p>
          <form class="newsletter-form" onsubmit="return false">
            <input type="email" placeholder="Enter your email address" required aria-label="Email address" />
            <button type="submit">Subscribe Free</button>
          </form>
          <p class="newsletter-trust">🔒 No spam. Unsubscribe anytime.</p>
        </div>
        <div class="newsletter-image">
          <img src="/images/newsletter-illustration.png" alt="Newsletter illustration" />
        </div>
      </div>
    </div>
  </div>
</section>
</main>

<!-- FOOTER -->
<footer>
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
  <a href="/" class="logo">
<img src="/images/dark-logo.png" alt="DesignTechNews" class="logo-img" />
  </a>
  <p>Discover design and technology opportunities across Africa and the global tech ecosystem.</p>
 <div class="social-links">
  <a href="#" class="social-link" aria-label="X (Twitter)">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
      <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.253 5.622 5.912-5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
    </svg>
  </a>
  <a href="#" class="social-link" aria-label="LinkedIn">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
      <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
    </svg>
  </a>
  <a href="#" class="social-link" aria-label="Instagram">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
      <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
    </svg>
  </a>
  <a href="#" class="social-link" aria-label="YouTube">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
      <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
    </svg>
  </a>
</div>
</div>
      <div class="footer-col">
        <h5>Explore</h5>
        <ul class="footer-links">
          <li><a href="/opportunities">Opportunities</a></li>
          <li><a href="/jobs">Tech Jobs</a></li>
          <li><a href="/news">News</a></li>
          <li><a href="#newsletter">Newsletter</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h5>Categories</h5>
        <ul class="footer-links">
          <li><a href="/opportunities">Scholarships</a></li>
          <li><a href="/opportunities">Fellowships</a></li>
          <li><a href="/opportunities">Accelerators</a></li>
          <li><a href="/opportunities">Competitions</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h5>Company</h5>
        <ul class="footer-links">
          <li><a href="#">About Us</a></li>
          <li><a href="#">Submit Opportunity</a></li>
          <li><a href="#">Advertise</a></li>
          <li><a href="#">Contact</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© 2025 DesignTechNews. All rights reserved.</span>
      <span style="display:flex;gap:20px;">
        <a href="#">Privacy Policy</a>
        <a href="#">Terms of Service</a>
      </span>
    </div>
  </div>
</footer>

<script src="/script.js" is:inline></script>
</body>
</html>