<!-- HERO -->
<main>
<section class="hero">
  <div class="container">
    <div class="hero-badge">🌍 Africa + Global Tech Ecosystem</div>
    <h1>
      Your hub for <span class="accent">design</span> &amp;<br>
      <span class="accent-green">tech</span> opportunities
    </h1>
    <p>Discover scholarships, fellowships, top tech jobs, and industry news — curated for designers, developers, and builders across Africa and the world.</p>
    <div class="hero-actions">
      <a href="opportunities.html" class="btn-primary">Browse Opportunities →</a>
      <a href="jobs.html" class="btn-secondary">View Tech Jobs</a>
    </div>
    <div class="hero-stats">
      <div class="stat">
        <span class="stat-num">200+</span>
        <span class="stat-label">Active Opportunities</span>
      </div>
      <div class="stat">
        <span class="stat-num">150+</span>
        <span class="stat-label">Tech Jobs Listed</span>
      </div>
      <div class="stat">
        <span class="stat-num">50+</span>
        <span class="stat-label">Countries Covered</span>
      </div>
      <div class="stat">
        <span class="stat-num">12K+</span>
        <span class="stat-label">Monthly Readers</span>
      </div>
    </div>
  </div>
</section>

<!-- FEATURED OPPORTUNITIES -->
<section>
  <div class="container">
    <div class="section-header">
      <div>
        <p class="section-label">🎯 Featured</p>
        <h2 class="section-title">Top Opportunities</h2>
      </div>
      <a href="opportunities.html" class="view-all">View all →</a>
    </div>
    <div class="card-grid">
      <article class="card fade-up" data-category="fellowship">
        <span class="card-tag tag-fellowship">Fellowship</span>
        <h3>Google for Startups Africa Founders Fund</h3>
        <div class="card-meta">
          <span>🌍 Pan-Africa</span>
          <span class="dot"></span>
          <span>Google</span>
        </div>
        <p>Equity-free funding and technical support for early-stage African startups building with AI. Open to founders from all 54 African countries.</p>
        <div class="card-footer">
          <span class="deadline urgent">⏰ Closes Jul 15, 2025</span>
          <a href="post-template.html" class="btn-card">Learn More →</a>
        </div>
      </article>

      <article class="card fade-up" data-category="scholarship">
        <span class="card-tag tag-scholarship">Scholarship</span>
        <h3>Mastercard Foundation Scholars Program</h3>
        <div class="card-meta">
          <span>🌍 Africa</span>
          <span class="dot"></span>
          <span>Multiple Universities</span>
        </div>
        <p>Full scholarships for academically gifted yet economically disadvantaged young Africans to study at leading universities globally.</p>
        <div class="card-footer">
          <span class="deadline">📅 Closes Sep 30, 2025</span>
          <a href="post-template.html" class="btn-card">Learn More →</a>
        </div>
      </article>

      <article class="card fade-up" data-category="accelerator">
        <span class="card-tag tag-accelerator">Accelerator</span>
        <h3>Y Combinator W2026 Batch</h3>
        <div class="card-meta">
          <span>🇺🇸 San Francisco / Remote</span>
          <span class="dot"></span>
          <span>Y Combinator</span>
        </div>
        <p>The world's most prestigious startup accelerator. $500K investment for 7% equity. Open to global founders including Africans.</p>
        <div class="card-footer">
          <span class="deadline">📅 Closes Oct 1, 2025</span>
          <a href="post-template.html" class="btn-card">Learn More →</a>
        </div>
      </article>
    </div>
  </div>
</section>

<!-- FEATURED JOBS -->
<section class="bg-subtle">
  <div class="container">
    <div class="section-header">
      <div>
        <p class="section-label">💼 Hiring Now</p>
