          <input type="email" placeholder="Enter your email address" required aria-label="Email address" />
          <button type="submit">Subscribe Free</button>
        </form>
        <p class="newsletter-trust">🔒 No spam. Unsubscribe anytime.</p>
      </div>
    </div>
  </div>
</section>
