    </div>
    <div style="display: flex; flex-direction: column; gap: 14px;">
      <article class="job-card fade-up">
        <div class="job-left">
          <div class="company-logo">SF</div>
          <div class="job-info">
            <h4>Senior Product Designer</h4>
            <p class="company">Shopify</p>
