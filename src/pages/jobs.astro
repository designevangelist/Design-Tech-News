    </svg>
  </a>
</div>
</div>
      <div class="footer-col">
        <h5>Explore</h5>
        <ul class="footer-links">
          <li><a href="/opportunities">Opportunities</a></li>
          <li><a href="/jobs">Tech Jobs</a></li>
          <li><a href="/news">News</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h5>Job Types</h5>
        <ul class="footer-links">
          <li><a href="/jobs">Design Jobs</a></li>
          <li><a href="/jobs">Engineering Jobs</a></li>
