---
import { getCollection } from "astro:content";
const jobs = await getCollection("jobs");
---

<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Tech Jobs – DesignTechNews</title>
  <meta name="description" content="Find design and tech jobs from top companies worldwide. Remote, hybrid, and on-site opportunities for designers and developers." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>

<nav class="mobile-nav" id="mobileNav">
  <button class="mobile-close" id="mobileClose">✕</button>
  <a href="/">Home</a>
  <a href="/opportunities">Opportunities</a>
  <a href="/jobs">Jobs</a>
  <a href="/news">News</a>
</nav>

<header>
  <div class="container">
    <nav>
      <a href="/" class="logo">
  <img src="/images/light-logo.png" alt="DesignTechNews" class="logo-img logo-light" />
  <img src="/images/dark-logo.png" alt="DesignTechNews" class="logo-img logo-dark" />
</a>
      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/opportunities">Opportunities</a></li>
        <li><a href="/jobs" class="active">Jobs</a></li>
        <li><a href="/news">News</a></li>
      </ul>
      <div class="nav-right">
        <button class="theme-toggle" id="themeToggle" aria-label="Toggle dark mode">🌙</button>
        <a href="/#newsletter" class="btn-subscribe">Subscribe</a>
        <button class="hamburger" id="hamburger"><span></span><span></span><span></span></button>
      </div>
    </nav>
  </div>
</header>

<main>
<section class="page-hero">
  <div class="container">
    <p class="section-label">💼 Jobs Board</p>
    <h1>Design &amp; Tech Jobs</h1>
    <p>Curated openings at top companies — remote-friendly roles for designers, developers, and tech professionals.</p>
  </div>
</section>

<section style="padding-top: 0;">
  <div class="container">
    <div class="search-bar">
      <span class="search-icon">🔍</span>
      <input type="text" id="searchInput" placeholder="Search jobs, companies, skills..." />
    </div>

    <div class="filter-bar">
      <button class="filter-btn active" data-filter="all">All</button>
<button class="filter-btn" data-filter="design">Design</button>
<button class="filter-btn" data-filter="engineering">Engineering</button>
<button class="filter-btn" data-filter="product">Product</button>
<button class="filter-btn" data-filter="data">Data & AI</button>
    </div>

    <div class="card-grid">
  {jobs.map((job) => (
    <article class="job-card-v" data-category={job.data.jobType.toLowerCase()}>
      <div class="company-logo">
        {job.data.company.slice(0, 2).toUpperCase()}
      </div>
      <div class="job-info">
        <h4>{job.data.title}</h4>
        <p class="company">{job.data.company} · {job.data.location}</p>
        <div class="job-tags" style="margin: 8px 0;">
          <span class="card-tag tag-remote" style="margin:0">
            {job.data.location.toLowerCase().includes("remote") ? "Remote" : "On-site"}
          </span>
          <span class="card-tag tag-fulltime" style="margin:0">{job.data.jobType}</span>
        </div>
        <div style="display:flex;align-items:center;justify-content:space-between;margin-top:12px;">
          {job.data.salary && (
            <span style="font-size:13px;color:var(--text-muted);font-weight:600;">{job.data.salary}</span>
          )}
          <a href={`/jobs/${job.id}`} class="btn-card">Apply →</a>
        </div>
      </div>
    </article>
  ))}
</div>
  </div>
</section>

<!-- Post a Job CTA -->
<section>
  <div class="container">
    <div style="background:linear-gradient(135deg,rgba(37,99,235,0.06),rgba(34,197,94,0.05));border:1.5px solid rgba(37,99,235,0.12);border-radius:20px;padding:48px;text-align:center;">
      <p class="section-label" style="text-align:center;margin-bottom:12px;">📢 Hiring?</p>
      <h2 style="font-size:clamp(1.6rem,3vw,2.2rem);margin-bottom:12px;letter-spacing:-0.5px;">Post a Job on DesignTechNews</h2>
      <p style="color:var(--text-muted);max-width:480px;margin:0 auto 28px;">Reach 12,000+ design and tech professionals across Africa and globally. Get qualified applicants fast.</p>
      <a href="mailto:jobs@designtechnews.com" class="btn-primary" style="display:inline-flex;margin:0 auto;">Post a Job →</a>
    </div>
  </div>
</section>
</main>

<footer>
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
  <a href="/" class="logo">
<img src="/images/dark-logo.png" alt="DesignTechNews" class="logo-img" />
  </a>
  <p>Discover design and technology opportunities across Africa and the global tech ecosystem.</p>
 <div class="social-links">
  <a href="#" class="social-link" aria-label="X (Twitter)">
