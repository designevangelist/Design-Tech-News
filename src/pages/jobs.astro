<script src="/script.js" is:inline></script>
<script is:inline>
  // Popup open/close
  const jobPopup = document.getElementById('jobPopup');
  const jobPopupClose = document.getElementById('jobPopupClose');

  jobPopupClose?.addEventListener('click', () => jobPopup.classList.remove('open'));
  jobPopup?.addEventListener('click', (e) => {
    if (e.target === jobPopup) jobPopup.classList.remove('open');
  });

  // Post job form submission
  const postJobForm = document.getElementById('post-job-form');
  if (postJobForm) {
    postJobForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = postJobForm.querySelector('button[type="submit"]');
      btn.textContent = 'Submitting...';
      btn.disabled = true;

      const response = await fetch(postJobForm.action, {
        method: 'POST',
        body: new FormData(postJobForm),
        headers: { 'Accept': 'application/json' }
      });

      if (response.ok) {
        document.getElementById('job-form-content').style.display = 'none';
        document.getElementById('job-form-success').style.display = 'flex';
      } else {
        btn.textContent = 'Submit Job Posting →';
        btn.disabled = false;
        alert('Something went wrong. Please try again.');
      }
    });
  }
</script>
</body>
