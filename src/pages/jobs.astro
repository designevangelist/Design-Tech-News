---
import { getCollection } from "astro:content";
const jobs = await getCollection("jobs");
---

<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Tech Jobs – DesignTechNews</title>
  <meta name="description" content="Find design and tech jobs from top companies worldwide. Remote, hybrid, and on-site opportunities for designers and developers." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="/styles.css" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
</head>
<body>

<!-- POST A JOB POPUP -->
<div class="popup-overlay" id="jobPopup">
  <div class="popup-box" style="max-width:580px;">
    <button class="popup-close" id="jobPopupClose">✕</button>
    <div id="job-form-content">
      <h3>Post a Job</h3>
      <p class="popup-sub">Reach 12,000+ designers and developers across Africa and globally.</p>
      <form id="post-job-form" action="https://formspree.io/f/meerlvee" method="POST">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
          <div class="form-group">
            <label>Your Name *</label>
            <input type="text" name="name" required placeholder="John Doe" />
          </div>
          <div class="form-group">
            <label>Your Email *</label>
            <input type="email" name="email" required placeholder="you@company.com" />
          </div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
          <div class="form-group">
            <label>Job Title *</label>
            <input type="text" name="title" required placeholder="e.g. Senior Product Designer" />
          </div>
          <div class="form-group">
            <label>Company *</label>
            <input type="text" name="company" required placeholder="Company name" />
          </div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
          <div class="form-group">
            <label>Location *</label>
            <input type="text" name="location" required placeholder="Remote / Lagos / Berlin" />
          </div>
          <div class="form-group">
            <label>Job Type *</label>
            <select name="jobType" required>
              <option value="">Select type</option>
              <option>Full-time</option>
              <option>Part-time</option>
              <option>Contract</option>
              <option>Internship</option>
            </select>
          </div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
          <div class="form-group">
            <label>Salary Range</label>
            <input type="text" name="salary" placeholder="e.g. $80K–$120K" />
          </div>
          <div class="form-group">
            <label>Apply Link *</label>
            <input type="url" name="link" required placeholder="https://..." />
          </div>
        </div>
        <div class="form-group">
          <label>Job Description *</label>
          <textarea name="description" required placeholder="Describe the role, requirements and responsibilities..."></textarea>
        </div>
        <button type="submit" class="btn-primary" style="width:100%;justify-content:center;">Submit Job Posting →</button>
      </form>
    </div>
    <div id="job-form-success" style="display:none;flex-direction:column;align-items:center;text-align:center;padding:20px 0;gap:16px;">
      <div class="success-check">
        <svg viewBox="0 0 52 52" class="checkmark-svg">
          <circle class="checkmark-circle" cx="26" cy="26" r="25" fill="none"/>
          <path class="checkmark-check" fill="none" d="M14.1 27.2l7.1 7.2 16.7-16.8"/>
        </svg>
      </div>
      <h3>Job Submitted! 🎉</h3>
      <p style="color:var(--text-muted);font-size:14px;">We'll review your listing and publish it within 24 hours.</p>
    </div>
  </div>
</div>

<nav class="mobile-nav" id="mobileNav">
  <button class="mobile-close" id="mobileClose">✕</button>
  <a href="/">Home</a>
  <a href="/opportunities">Opportunities</a>
  <a href="/jobs">Jobs</a>
  <a href="/news">News</a>
  <a href="/about">About</a>
</nav>

<header>
  <div class="container">
    <nav>
      <a href="/" class="logo">
        <img src="/images/light-logo.png" alt="DesignTechNews" class="logo-img logo-light" />
        <img src="/images/dark-logo.png" alt="DesignTechNews" class="logo-img logo-dark" />
      </a>
      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/opportunities">Opportunities</a></li>
        <li><a href="/jobs" class="active">Jobs</a></li>
        <li><a href="/news">News</a></li>
        <li><a href="/about">About</a></li>
      </ul>
      <div class="nav-right">
        <button class="theme-toggle" id="themeToggle" aria-label="Toggle dark mode">🌙</button>
        <button onclick="document.getElementById('jobPopup').classList.add('open')" class="btn-subscribe">Post a Job</button>
        <button class="hamburger" id="hamburger"><span></span><span></span><span></span></button>
      </div>
    </nav>
  </div>
</header>

<main>
<section class="page-hero">
  <div class="container">
    <p class="section-label">💼 Jobs Board</p>
    <h1>Design &amp; Tech Jobs</h1>
    <p>Curated openings at top companies — remote-friendly roles for designers, developers, and tech professionals.</p>
  </div>
</section>

<section style="padding-top: 0;">
  <div class="container">
    <div class="search-bar">
      <span class="search-icon">🔍</span>
      <input type="text" id="searchInput" placeholder="Search jobs, companies, skills..." />
    </div>

    <div class="filter-bar">
      <button class="filter-btn active" data-filter="all">All</button>
      <button class="filter-btn" data-filter="design">Design</button>
      <button class="filter-btn" data-filter="engineering">Engineering</button>
      <button class="filter-btn" data-filter="product">Product</button>
      <button class="filter-btn" data-filter="data">Data & AI</button>
    </div>

    <div class="card-grid jobs-list">
      {jobs.map((job) => (
        <article class="job-card-v" data-category={job.data.jobType?.toLowerCase()}>
  <div class="company-logo-wrap">
    {job.data.logo ? (
      <img src={job.data.logo} alt={job.data.company} class="company-logo-img" />
    ) : (
      <div class="company-logo">
        {job.data.company.slice(0, 2).toUpperCase()}
      </div>
    )}
  </div>
  <div class="job-info">
    <h4 class="job-title-clamp">{job.data.title}</h4>
    <p class="company company-clamp">{job.data.company}</p>
    <div class="job-tags" style="margin: 8px 0;">
      {job.data.jobType && (
  <span class="card-tag tag-fulltime" style="margin:0">{job.data.jobType}</span>
)}
{!job.data.jobType && (
  <span class="card-tag tag-fulltime" style="margin:0">Full-time</span>
)}
      {job.data.location?.toLowerCase().includes("remote") && (
        <span class="card-tag tag-remote" style="margin:0">Remote</span>
      )}
    </div>
    <div style="display:flex;align-items:center;justify-content:space-between;margin-top:12px;">
      {job.data.salary && (
        <span style="font-size:13px;color:var(--text-muted);font-weight:600;">{job.data.salary}</span>
      )}
      <a href={job.data.link ? job.data.link : `/jobs/${job.id}`} target={job.data.link ? "_blank" : "_self"} rel="noopener noreferrer" class="btn-card">Apply →</a>
    </div>
  </div>
</article>
      ))}
    </div>
  </div>
</section>

<!-- Post a Job CTA -->
<section>
  <div class="container">
    <div style="background:linear-gradient(135deg,rgba(37,99,235,0.06),rgba(34,197,94,0.05));border:1.5px solid rgba(37,99,235,0.12);border-radius:20px;padding:48px;text-align:center;">
      <p class="section-label" style="text-align:center;margin-bottom:12px;">📢 Hiring?</p>
      <h2 style="font-size:clamp(1.6rem,3vw,2.2rem);margin-bottom:12px;letter-spacing:-0.5px;">Post a Job on DesignTechNews</h2>
      <p style="color:var(--text-muted);max-width:480px;margin:0 auto 28px;">Reach 12,000+ design and tech professionals across Africa and globally. Get qualified applicants fast.</p>
      <button onclick="document.getElementById('jobPopup').classList.add('open')" class="btn-primary" style="display:inline-flex;margin:0 auto;">Post a Job →</button>
    </div>
  </div>
</section>
</main>

<!-- NEWSLETTER CTA -->
<section style="padding: 48px 0;">
  <div class="container">
    <div class="newsletter-section" style="padding: 40px 48px;">
      <div class="newsletter-layout">
        <div class="newsletter-inner">
          <p class="section-label">📬 Never miss an update</p>
          <h2 style="font-size:clamp(1.5rem,2.5vw,2rem);">Get weekly design & tech opportunities</h2>
          <form class="newsletter-form newsletter-sub" style="position:relative;margin-top:20px;">
            <input type="email" name="EMAIL" placeholder="Enter your email address" required aria-label="Email address" />
            <div style="position:absolute;left:-5000px;" aria-hidden="true">
              <input type="text" name="b_3b667d867a0c7d77bc2de09db_3d67b5db75" tabindex="-1" value="" />
            </div>
            <button type="submit">Subscribe Free</button>
          </form>
          <p class="newsletter-trust">🔒 No spam. Unsubscribe anytime.</p>
        </div>
        <div class="newsletter-image newsletter-sub-success" style="display:none;flex-direction:column;align-items:center;justify-content:center;text-align:center;gap:12px;">
          <div class="success-check">
            <svg viewBox="0 0 52 52" class="checkmark-svg">
              <circle class="checkmark-circle" cx="26" cy="26" r="25" fill="none"/>
              <path class="checkmark-check" fill="none" d="M14.1 27.2l7.1 7.2 16.7-16.8"/>
            </svg>
          </div>
          <p style="color:white;font-weight:700;font-size:1.1rem;margin:0;">You're in! 🎉</p>
          <p style="color:rgba(255,255,255,0.65);font-size:0.9rem;margin:0;">Check your inbox for a confirmation email.</p>
        </div>
      </div>
    </div>
  </div>
</section>

